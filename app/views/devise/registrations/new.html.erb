<div class="auth-container">
  <h2 class="auth-title">Create Account</h2>
  <p class="auth-subtitle">Join us and start shopping today</p>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="form-group">
      <%= f.label :email, "Email Address", class: "form-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :password, "Password", class: "form-label" %>
      <% if @minimum_password_length %>
        <em class="password-hint">(Minimum <%= @minimum_password_length %> characters)</em>
      <% end %>
      <%= f.password_field :password, autocomplete: "new-password", class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.submit "Sign Up", class: "btn-primary btn-block" %>
    </div>
  <% end %>

  <div class="auth-footer-links">
    <%= link_to "Already have an account? Login", new_session_path(resource_name), class: "nav-link small-link" %>
  </div>
</div>
