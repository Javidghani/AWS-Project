<h1 class="page-title">Categories</h1>

<div class="categories-grid">
  <% categories = [
    { 
    name: "Sportswear", 
description: "High quality sports clothing and accessories for all your athletic needs.",
image_url: "https://images.unsplash.com/photo-1558151507-c1aa3d917dbb?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
path: category_products_path("sportswear")

    },
    { 
      name: "Electronics", 
      description: "Latest gadgets, smart devices, and electronics to keep you connected.",
      image_url: "https://images.unsplash.com/photo-1601679249486-3e2a903f23ee?q=80&w=765&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
      path: category_products_path("electronics")
    },
    { 
      name: "Footwear", 
      description: "Comfortable and stylish shoes for every occasion.",
      image_url: "https://images.unsplash.com/photo-1581079732262-559fe855062c?q=80&w=1235&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
      path: category_products_path("footwear")
    },
    { 
      name: "Outdoor", 
      description: "Gear and apparel for outdoor adventures and activities.",
      image_url: "https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=600&q=80",
      path: category_products_path("outdoor")
    },
    { 
      name: "Fitness", 
      description: "Equipment and accessories to keep you fit and healthy.",
      image_url: "https://images.unsplash.com/photo-1517836357463-d25dfeac3438?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
      path: category_products_path("fitness")
    },
    { 
      name: "Casual Wear", 
      description: "Everyday comfortable and trendy clothing for casual outings.",
      image_url: "https://images.unsplash.com/photo-1514996937319-344454492b37?auto=format&fit=crop&w=600&q=80",
      path: category_products_path("casual-wear")
    }
  ] %>

  <% categories.each do |category| %>
    <%= link_to category[:path], class: "category-card" do %>
      <div class="category-image-wrapper">
        <img src="<%= category[:image_url] %>" alt="<%= category[:name] %>" loading="lazy" />
      </div>
      <h2 class="category-name"><%= category[:name] %></h2>
      <p class="category-description"><%= category[:description] %></p>
    <% end %>
  <% end %>
</div>

<style>
  /* Page title */
  .page-title {
    font-size: 3rem;
    font-weight: 800;
    text-align: center;
    margin: 3rem 0 4rem 0;
    color: #222;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    letter-spacing: 0.06em;
  }

  /* Grid container */
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2.5rem;
    max-width: 1100px;
    margin: 0 auto 5rem auto;
    padding: 0 1rem;
  }

  /* Category card as link */
  .category-card {
    background-color: #ffffff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    transition: transform 0.35s ease, box-shadow 0.35s ease;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    text-align: center;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    text-decoration: none;
    color: inherit;
  }

  /* Hover effect */
  .category-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.18);
  }

  /* Image wrapper */
  .category-image-wrapper {
    width: 100%;
    height: 180px;
    overflow: hidden;
  }

  .category-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .category-card:hover .category-image-wrapper img {
    transform: scale(1.07);
  }

  /* Category name */
  .category-name {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 1.5rem 0 0.75rem 0;
    color: #0056b3;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Category description */
  .category-description {
    font-size: 1.05rem;
    color: #555;
    padding: 0 1.5rem 2rem 1.5rem;
    line-height: 1.6;
  }

  /* Responsive tweaks */
  @media (max-width: 480px) {
    .page-title {
      font-size: 2.2rem;
      margin: 2rem 0 2.5rem 0;
    }

    .category-image-wrapper {
      height: 140px;
    }

    .category-name {
      font-size: 1.4rem;
    }

    .category-description {
      font-size: 0.95rem;
      padding: 0 1rem 1.5rem 1rem;
    }
  }
</style>
